---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import projects from '../data/projects.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Projects" description="Projects and work" />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 1em;
			}
			.projects-grid {
				display: grid;
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.project-card {
				border: 1px solid rgba(var(--black), 10%);
				border-radius: 12px;
				padding: 1.5rem;
				transition: box-shadow 0.2s ease;
			}
			.project-card:hover {
				box-shadow: var(--box-shadow);
			}
			.project-card a {
				text-decoration: none;
				color: inherit;
			}
			.project-card h3 {
				margin: 0 0 0.5em 0;
				color: rgb(var(--accent));
			}
			.project-card p {
				margin: 0.5em 0;
				color: rgb(var(--gray-dark));
			}
			.tech {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.5em;
			}
			.tech span {
				background: rgba(var(--accent), 0.2);
				padding: 0.25em 0.5em;
				border-radius: 4px;
				font-size: 0.875em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<ul class="projects-grid">
				{
					projects.map((project) => (
						<li class="project-card">
							<a href={project.link} target="_blank" rel="noopener noreferrer">
								<h3>{project.title}</h3>
								<p>{project.description}</p>
								{project.tech && project.tech.length > 0 && (
									<div class="tech">
										{project.tech.map((t) => (
											<span>{t}</span>
										))}
									</div>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
